{
  "kafka": {
    "BootstrapServers": "localhost:9092",
    "ClientId": "LaptopStore-Producer"
  },
  "JwtSettings": {
    "Issuer": "LaptopStore.API",
    "Audience": "LaptopStore.Client",
    "AccessTokenExpireMinutes": 15,
    "RefreshTokenExpireDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
